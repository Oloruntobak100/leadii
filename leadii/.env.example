# ============================================
# Leadii - Environment Configuration
# ============================================

# --------------------------------------------
# Application
# --------------------------------------------
NEXT_PUBLIC_APP_NAME=Leadii
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --------------------------------------------
# Database (Supabase)
# --------------------------------------------
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=[your-anon-key]
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]

# --------------------------------------------
# Authentication (NextAuth)
# --------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=[generate-with-openssl-rand-base64-32]

# OAuth Providers
GOOGLE_CLIENT_ID=[your-google-client-id]
GOOGLE_CLIENT_SECRET=[your-google-client-secret]
LINKEDIN_CLIENT_ID=[your-linkedin-client-id]
LINKEDIN_CLIENT_SECRET=[your-linkedin-client-secret]

# --------------------------------------------
# AI APIs
# --------------------------------------------
OPENAI_API_KEY=sk-[your-openai-key]
ANTHROPIC_API_KEY=sk-ant-[your-anthropic-key]
PERPLEXITY_API_KEY=pplx-[your-perplexity-key]

# LangChain Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=[your-langchain-key]
LANGCHAIN_PROJECT=leadii

# --------------------------------------------
# Redis (Upstash or self-hosted)
# --------------------------------------------
REDIS_HOST=[your-redis-host]
REDIS_PORT=6379
REDIS_PASSWORD=[your-redis-password]
REDIS_URL=redis://:[password]@[host]:[port]

# --------------------------------------------
# Stripe (Payments)
# --------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_[your-key]
STRIPE_SECRET_KEY=sk_test_[your-key]
STRIPE_WEBHOOK_SECRET=whsec_[your-webhook-secret]

# Stripe Price IDs
STRIPE_PRICE_STARTER=price_[starter-price-id]
STRIPE_PRICE_PROFESSIONAL=price_[pro-price-id]
STRIPE_PRICE_ENTERPRISE=price_[enterprise-price-id]

# --------------------------------------------
# Communication APIs
# --------------------------------------------
# Twilio (SMS & WhatsApp)
TWILIO_ACCOUNT_SID=AC[your-account-sid]
TWILIO_AUTH_TOKEN=[your-auth-token]
TWILIO_PHONE_NUMBER=+[your-phone-number]
TWILIO_WHATSAPP_NUMBER=+[your-whatsapp-number]

# Resend (Email)
RESEND_API_KEY=re_[your-resend-key]
RESEND_FROM_EMAIL=noreply@leadii.io
RESEND_FROM_NAME=Leadii

# LinkedIn API
LINKEDIN_API_KEY=[your-linkedin-api-key]

# --------------------------------------------
# External Data Sources
# --------------------------------------------
# Google Custom Search
GOOGLE_SEARCH_API_KEY=[your-google-api-key]
GOOGLE_SEARCH_ENGINE_ID=[your-search-engine-id]

# Apollo.io
APOLLO_API_KEY=[your-apollo-key]

# Hunter.io
HUNTER_API_KEY=[your-hunter-key]

# Crunchbase
CRUNCHBASE_API_KEY=[your-crunchbase-key]

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------
SENTRY_DSN=[your-sentry-dsn]
LOGROCKET_APP_ID=[your-logrocket-id]

# --------------------------------------------
# Feature Flags
# --------------------------------------------
ENABLE_SOCIAL_SCRAPING=false
ENABLE_WHATSAPP=true
ENABLE_SMS=true
ENABLE_LINKEDIN_DM=false
MAX_LEADS_PER_CAMPAIGN=1000
MAX_CONCURRENT_ENRICHMENTS=5
