# Copy to `.env` in this folder for local dev (`cp .env.example .env` or duplicate in your editor).
# On Vercel: Project → Settings → Environment Variables — use the SAME names (must start with VITE_).
#
# Use the anon / public key only (Supabase → Project Settings → API). Never the service_role secret.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key
